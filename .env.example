# To create or update a token visit https://envio.dev/app/api-tokens
ENVIO_API_TOKEN="<YOUR-API-TOKEN>"

# Optional: Dedicated IPFS gateway URL (e.g. Filebase, Pinata)
# Falls back to public gateways if not set
ENVIO_IPFS_GATEWAY_URL=""

# --- RPC API Keys ---
# dRPC key (used across all chains) - https://drpc.org
NODES_DRPC_API_KEY=""

# Alchemy key (used across all chains) - https://alchemy.com
NODES_ALCHEMY_API_KEY=""

# --- Custom RPC URLs (chains without dRPC/Alchemy support) ---
NODES_KATANA_RPC_URL=""
NODES_PEAQ_RPC_URL=""
NODES_CHILIZ_RPC_URL=""

# --- Pinata IPFS Gateway (public for reads, no auth needed) ---
PINATA_GATEWAY_URI="https://aragon-1.mypinata.cloud/ipfs"

# --- Etherscan v2 API (multi-chain, single key) ---
ETHERSCAN_API_KEY=""
ETHERSCAN_API_BASE_URL="https://api.etherscan.io/v2/api"
