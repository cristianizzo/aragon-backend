# =============================================================================
# Envio
# =============================================================================
# Hosted-service token; only required for Envio cloud deployments.
ENVIO_API_TOKEN="<YOUR-API-TOKEN>"

# =============================================================================
# RPC providers
# =============================================================================
# Handler-time RPC reads (bytecode detection, ENS, escrow settings, etc.) use
# the same providers as HyperSync. Resolution order per chain:
#   1. ENVIO_RPC_URL_<chainId>   — explicit per-chain override (always wins)
#   2. DRPC                — if ENVIO_NODES_DRPC_API_KEY is set
#   3. Alchemy             — if ENVIO_NODES_ALCHEMY_API_KEY is set
#   4. Public fallback     — heavily rate-limited, may silently drop requests
ENVIO_ENVIO_NODES_DRPC_API_KEY=""
ENVIO_ENVIO_NODES_ALCHEMY_API_KEY=""

# Per-chain override URLs. Set ONLY when you need to bypass DRPC/Alchemy
# defaults for a specific chain (custom provider, archive node, etc.).
# Chain ids match src/config/index.ts:rpcUrls().
ENVIO_RPC_URL_1=""           # ethereum
ENVIO_RPC_URL_10=""          # optimism
ENVIO_RPC_URL_137=""         # polygon
ENVIO_RPC_URL_324=""         # zksync (no DRPC/Alchemy support — uses public default)
ENVIO_RPC_URL_3338=""        # peaq (no DRPC/Alchemy)
ENVIO_RPC_URL_4114=""        # citrea (no DRPC/Alchemy)
ENVIO_RPC_URL_8453=""        # base
ENVIO_RPC_URL_42161=""       # arbitrum
ENVIO_RPC_URL_43114=""       # avalanche
ENVIO_RPC_URL_88888=""       # chiliz (no DRPC/Alchemy)
ENVIO_RPC_URL_747474=""      # katana (no DRPC/Alchemy)
ENVIO_RPC_URL_11155111=""    # ethereum sepolia

# =============================================================================
# IPFS
# =============================================================================
# Pinata gateway is the primary read path; public gateways below are tried
# in order on miss. Per-chain routing in src/helpers/explorers/routing.ts.
ENVIO_PINATA_GATEWAY_URI="https://aragon-1.mypinata.cloud/ipfs/"
ENVIO_IPFS_GATEWAY_URL=""                 # optional dedicated gateway (Filebase, Pinata, etc.)
ENVIO_IPFS_PUBLIC_GATEWAYS="https://ipfs.io/ipfs/,https://dweb.link/ipfs/,https://cloudflare-ipfs.com/ipfs/"
ENVIO_IPFS_FETCH_TIMEOUT_MS="10000"

# =============================================================================
# Block-explorer APIs
# =============================================================================
# ABI / source-code lookup for the proposal-action decoder. Currently the
# decoder uses ETHERSCAN ONLY; the per-chain fallbacks below are wired in
# config/index.ts and waiting for the multi-chain explorer router (see
# src/helpers/explorers/). Until that lands, action decoding on the
# fallback chains degrades to the 4byte signature lookup.

# Etherscan v2 — multi-chain (most EVM chains).
ENVIO_ETHERSCAN_API_KEY=""
ENVIO_ETHERSCAN_API_BASE_URL="https://api.etherscan.io/v2/api"

# Routescan — fallback for Avalanche (43114) and any chain Etherscan v2
# misses. Free, no API key required.
ENVIO_ROUTESCAN_API_BASE_URL="https://api.routescan.io/v2/network/mainnet/evm"

# zkSync Era (324) — its own block-explorer API.
ENVIO_ZKSYNC_EXPLORER_MAINNET_BASE_URL="https://block-explorer-api.mainnet.zksync.io/api"

# Citrea (4114) — Blockscout instance.
ENVIO_BLOCKSCOUT_CITREA_BASE_URL="https://explorer.mainnet.citrea.xyz/api"

# Peaq (3338) — Substrate-based, uses Subscan. API key is optional
# (free tier is rate-limited).
ENVIO_SUBSCAN_PEAQ_BASE_URL="https://peaq.api.subscan.io"
ENVIO_SUBSCAN_API_KEY=""

# =============================================================================
# 4byte directory
# =============================================================================
# Selector → signature lookup. Used by the proposal-action decoder (Stage 4
# fallback) and the SelectorPermission decoder. No API key needed.
ENVIO_FOUR_BYTE_URI="https://www.4byte.directory/api/v1"

# =============================================================================
# Logging
# =============================================================================
ENVIO_LOG_LEVEL="info"
ENVIO_ENVIRONMENT="local"

# Logz.io shipping — leave LOGZIO_KEY blank to log to stdout only.
ENVIO_LOGZIO_KEY=""
ENVIO_LOGZIO_HOST="listener.logz.io"
ENVIO_LOGZIO_TYPE="aragon-indexer"