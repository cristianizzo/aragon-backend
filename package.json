{
  "name": "./aragon-indexer",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "codegen": "envio codegen && cd generated && pnpm install --shamefully-hoist --ignore-workspace && npx rescript build",
    "dev": "envio dev",
    "start": "envio start",
    "status": "docker exec envio-postgres psql -U postgres -d envio-dev -c \"SELECT id as chain, progress_block, source_block, events_processed, ready_at FROM envio_chains ORDER BY id;\"",
    "test": "vitest run",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --write src/ test/",
    "format": "biome format --write src/ test/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^24.10.1",
    "typescript": "5.9.3",
    "viem": "^2.47.5",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "bottleneck": "^2.19.5",
    "envio": "3.0.0-alpha.18",
    "logzio-nodejs": "^2.5.0",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0"
  },
  "optionalDependencies": {
    "generated": "./aragon-indexer/../generated"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
